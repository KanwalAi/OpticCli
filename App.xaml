<!--
    ================================================================
    File: App.xaml
    Project: OpticCli
    Namespace: OpticCli
    Description: Application entry point. Defines all global styles,
    colors, fonts, and control templates shared across
    every screen in the app.
    ================================================================
-->
<Application
    x:Class="OpticCli.App"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    StartupUri="Views/HomeView.xaml">
    <Application.Resources>

        <ResourceDictionary>

            <!--
                ═══════════════════════════════════════════
                COLOUR PALETTE
                ════════════════════════════════════════════
            -->
            <Color x:Key="BgColor">#0A0C10</Color>
            <Color x:Key="SurfaceColor">#0F1218</Color>
            <Color x:Key="Surface2Color">#080A0E</Color>
            <Color x:Key="BorderColor">#1E2430</Color>
            <Color x:Key="Border2Color">#2A3040</Color>
            <Color x:Key="TextColor">#C8D0E0</Color>
            <Color x:Key="MutedColor">#5A6478</Color>
            <Color x:Key="AccentColor">#00E5FF</Color>
            <Color x:Key="Accent2Color">#7C3AED</Color>
            <Color x:Key="GreenColor">#22C55E</Color>
            <Color x:Key="YellowColor">#F59E0B</Color>
            <Color x:Key="RedColor">#EF4444</Color>
            <Color x:Key="OrangeColor">#F97316</Color>

            <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
            <SolidColorBrush x:Key="SurfaceBrush" Color="{StaticResource SurfaceColor}" />
            <SolidColorBrush x:Key="Surface2Brush" Color="{StaticResource Surface2Color}" />
            <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
            <SolidColorBrush x:Key="Border2Brush" Color="{StaticResource Border2Color}" />
            <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
            <SolidColorBrush x:Key="MutedBrush" Color="{StaticResource MutedColor}" />
            <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
            <SolidColorBrush x:Key="Accent2Brush" Color="{StaticResource Accent2Color}" />
            <SolidColorBrush x:Key="GreenBrush" Color="{StaticResource GreenColor}" />
            <SolidColorBrush x:Key="YellowBrush" Color="{StaticResource YellowColor}" />
            <SolidColorBrush x:Key="RedBrush" Color="{StaticResource RedColor}" />

            <!--  Risk badge backgrounds  -->
            <SolidColorBrush x:Key="RiskSafeBg" Color="#1A22C55E" />
            <SolidColorBrush x:Key="RiskMedBg" Color="#1AF59E0B" />
            <SolidColorBrush x:Key="RiskHighBg" Color="#1AEF4444" />
            <SolidColorBrush x:Key="RiskSafeFg" Color="#22C55E" />
            <SolidColorBrush x:Key="RiskMedFg" Color="#F59E0B" />
            <SolidColorBrush x:Key="RiskHighFg" Color="#EF4444" />

            <!--
                ═══════════════════════════════════════════
                FONTS
                ════════════════════════════════════════════
            -->
            <FontFamily x:Key="MonoFont">Consolas, Courier New</FontFamily>
            <FontFamily x:Key="UIFont">Segoe UI</FontFamily>

            <!--
                ═══════════════════════════════════════════
                SHARED BUTTON STYLE  (Primary / Ghost)
                ════════════════════════════════════════════
            -->
            <Style x:Key="PrimaryBtn" TargetType="Button">
                <Setter Property="Background">
                    <Setter.Value>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                            <GradientStop Offset="0" Color="#2600E5FF" />
                            <GradientStop Offset="1" Color="#1400E5FF" />
                        </LinearGradientBrush>
                    </Setter.Value>
                </Setter>
                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderBrush" Value="#6600E5FF" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="20,10" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background">
                                        <Setter.Value>
                                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                                <GradientStop Offset="0" Color="#3300E5FF" />
                                                <GradientStop Offset="1" Color="#2600E5FF" />
                                            </LinearGradientBrush>
                                        </Setter.Value>
                                    </Setter>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Opacity" Value="0.85" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <Style x:Key="GhostBtn" TargetType="Button">
                <Setter Property="Background" Value="#0AFFFFFF" />
                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border2Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="16,9" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border
                                Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Shared text input style  -->
            <Style x:Key="DarkTextBox" TargetType="TextBox">
                <Setter Property="Background" Value="#0AFFFFFF" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="CaretBrush" Value="{StaticResource AccentBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border2Brush}" />
                <Setter Property="BorderThickness" Value="1.5" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Padding" Value="12,10" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="TextBox">
                            <Border
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                                <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}" />
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsFocused" Value="True">
                                    <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  Shared CheckBox style  -->
            <Style x:Key="DarkCheckBox" TargetType="CheckBox">
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="13" />
                <Setter Property="Cursor" Value="Hand" />
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="CheckBox">
                            <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                                <Border
                                    x:Name="CheckBox"
                                    Width="18"
                                    Height="18"
                                    Margin="0,0,10,0"
                                    Background="Transparent"
                                    BorderBrush="{StaticResource Border2Brush}"
                                    BorderThickness="1.5"
                                    CornerRadius="4">
                                    <TextBlock
                                        x:Name="Check"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        FontSize="11"
                                        FontWeight="Bold"
                                        Foreground="{StaticResource AccentBrush}"
                                        Text="✓"
                                        Visibility="Collapsed" />
                                </Border>
                                <ContentPresenter VerticalAlignment="Center" />
                            </StackPanel>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsChecked" Value="True">
                                    <Setter TargetName="CheckBox" Property="Background" Value="#2600E5FF" />
                                    <Setter TargetName="CheckBox" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                    <Setter TargetName="Check" Property="Visibility" Value="Visible" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!--  ComboBox dark style  -->
            <Style x:Key="DarkComboBox" TargetType="ComboBox">
                <Setter Property="Background" Value="#0AFFFFFF" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource Border2Brush}" />
                <Setter Property="BorderThickness" Value="1" />
                <Setter Property="Padding" Value="10,8" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="12" />
            </Style>

            <!--  DataGrid dark style  -->
            <Style x:Key="DarkDataGrid" TargetType="DataGrid">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="0" />
                <Setter Property="RowBackground" Value="Transparent" />
                <Setter Property="AlternatingRowBackground" Value="#050A0C10" />
                <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="VerticalGridLinesBrush" Value="Transparent" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="12" />
                <Setter Property="ColumnHeaderHeight" Value="38" />
                <Setter Property="RowHeight" Value="40" />
                <Setter Property="SelectionMode" Value="Extended" />
                <Setter Property="AutoGenerateColumns" Value="False" />
                <Setter Property="CanUserAddRows" Value="False" />
                <Setter Property="CanUserDeleteRows" Value="False" />
                <Setter Property="CanUserResizeRows" Value="False" />
                <Setter Property="IsReadOnly" Value="True" />
            </Style>

            <Style x:Key="DarkDataGridColumnHeader" TargetType="DataGridColumnHeader">
                <Setter Property="Background" Value="{StaticResource Surface2Brush}" />
                <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
                <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
                <Setter Property="FontSize" Value="11" />
                <Setter Property="FontWeight" Value="SemiBold" />
                <Setter Property="Padding" Value="14,0" />
                <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
                <Setter Property="BorderThickness" Value="0,0,0,1" />
                <Setter Property="Height" Value="38" />
            </Style>

            <Style x:Key="DarkDataGridRow" TargetType="DataGridRow">
                <Setter Property="Background" Value="Transparent" />
                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                <Style.Triggers>
                    <Trigger Property="IsMouseOver" Value="True">
                        <Setter Property="Background" Value="#08FFFFFF" />
                    </Trigger>
                    <Trigger Property="IsSelected" Value="True">
                        <Setter Property="Background" Value="#0D00E5FF" />
                    </Trigger>
                </Style.Triggers>
            </Style>
            <Style TargetType="Window">
                <Setter Property="WindowState" Value="Maximized" />
            </Style>
        </ResourceDictionary>
    </Application.Resources>
</Application>
