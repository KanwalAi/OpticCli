<!--
    ================================================================
    File: CustomizeView.xaml
    Project: OpticCli
    Namespace: OpticCli.Views
    Description: The command customization screen. Lets the user tweak
    parameters like path, filter, and flags before running
    or copying the AI-suggested PowerShell command.
    ================================================================
-->

<Window
    x:Class="OpticCli.Views.CustomizeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:OpticCli.Views"
    Title="OpticCli – Customize Command"
    Width="1100"
    Height="700"
    AllowsTransparency="True"
    Background="{StaticResource SurfaceBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <!--  Title Bar  -->
            <local:TitleBarControl Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

            <!--  Tab Bar  -->
            <Border
                Grid.Row="1"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
                <StackPanel
                    Margin="16,0"
                    VerticalAlignment="Stretch"
                    Orientation="Horizontal">
                    <Border
                        Width="1259"
                        Margin="0,0,0,-1"
                        Padding="16,0"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="0,0,0,0.8">

                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12"
                            Foreground="{StaticResource AccentBrush}"
                            Text="⌂  Terminal" />

                    </Border>

                </StackPanel>
            </Border>

            <!--  Body  -->
            <Grid Grid.Row="2" Margin="28,20,28,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!--  Live Command Preview  -->
                <Border
                    Grid.Row="0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="1"
                    CornerRadius="12">
                    <Border.Background>
                        <SolidColorBrush Color="#05FFFFFF" />
                    </Border.Background>
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="38" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Border
                            Grid.Row="0"
                            Padding="16,0"
                            Background="{StaticResource Surface2Brush}"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="0,0,0,1"
                            CornerRadius="12,12,0,0">
                            <Grid>
                                <TextBlock
                                    VerticalAlignment="Center"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="12"
                                    FontWeight="SemiBold"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="Review Code" />
                                <StackPanel
                                    HorizontalAlignment="Right"
                                    VerticalAlignment="Center"
                                    Orientation="Horizontal">
                                    <Ellipse
                                        Width="6"
                                        Height="6"
                                        Margin="0,0,6,0"
                                        Fill="{StaticResource YellowBrush}" />
                                    <TextBlock
                                        FontFamily="{StaticResource MonoFont}"
                                        FontSize="11"
                                        Foreground="{StaticResource YellowBrush}"
                                        Text="Live Preview" />
                                </StackPanel>
                            </Grid>
                        </Border>

                        <TextBlock
                            x:Name="LiveCmdText"
                            Grid.Row="1"
                            Padding="20,14"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="14"
                            FontWeight="SemiBold"
                            LineHeight="22"
                            TextWrapping="Wrap">
                            <Run Foreground="#8000E5FF" Text="PS› " />
                            <Run
                                x:Name="RunBaseName"
                                Foreground="#E2E8F0"
                                Text="" />
                            <Run
                                x:Name="RunRecurse"
                                Foreground="#A78BFA"
                                Text="" />
                            <Run
                                x:Name="RunPath"
                                Foreground="#F59E0B"
                                Text="" />
                            <Run
                                x:Name="RunForce"
                                Foreground="#A78BFA"
                                Text="" />
                            <Run
                                x:Name="RunFilter"
                                Foreground="#22C55E"
                                Text="" />
                        </TextBlock>
                    </Grid>
                </Border>

                <!--  Parameter Form  -->
                <ScrollViewer Grid.Row="2" VerticalScrollBarVisibility="Auto">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <!--  Target Path  -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="0"
                            Padding="16"
                            Background="#05FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <StackPanel>
                                <StackPanel Margin="0,0,0,10" Orientation="Horizontal">
                                    <TextBlock
                                        FontFamily="{StaticResource MonoFont}"
                                        FontSize="11"
                                        Foreground="{StaticResource MutedBrush}"
                                        Text="TARGET PATH" />
                                    <TextBlock
                                        Margin="6,0,0,0"
                                        FontFamily="{StaticResource MonoFont}"
                                        FontSize="10"
                                        Foreground="{StaticResource AccentBrush}"
                                        Text=" optional" />
                                </StackPanel>
                                <TextBox
                                    x:Name="PathInput"
                                    Style="{StaticResource DarkTextBox}"
                                    Text=""
                                    TextChanged="PathInput_TextChanged" />
                            </StackPanel>
                        </Border>

                        <!--  Filter Extension  -->
                        <Border
                            Grid.Row="0"
                            Grid.Column="2"
                            Padding="16"
                            Background="#05FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource MutedBrush}"
                                    Text="FILTER (EXTENSION)" />
                                <TextBox
                                    x:Name="ExtInput"
                                    Style="{StaticResource DarkTextBox}"
                                    Text=""
                                    TextChanged="ExtInput_TextChanged" />
                            </StackPanel>
                        </Border>

                        <!--  Options  -->
                        <Border
                            x:Name="OptionsPanel"
                            Grid.Row="2"
                            Grid.Column="0"
                            Padding="16"
                            Background="#05FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,12"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource MutedBrush}"
                                    Text="OPTIONS" />

                                <!--  Recurse  -->
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="13"
                                            Foreground="{StaticResource TextBrush}"
                                            Text="-Recurse" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="11"
                                            Foreground="{StaticResource MutedBrush}"
                                            Text="Search all subdirectories" />
                                    </StackPanel>
                                    <CheckBox
                                        x:Name="RecurseCheck"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Checked="RecurseCheck_Changed"
                                        Style="{StaticResource DarkCheckBox}"
                                        Unchecked="RecurseCheck_Changed" />
                                </Grid>

                                <!--  Force  -->
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="13"
                                            Foreground="{StaticResource TextBrush}"
                                            Text="-Force" />
                                        <TextBlock
                                            Margin="0,2,0,0"
                                            FontFamily="{StaticResource MonoFont}"
                                            FontSize="11"
                                            Foreground="{StaticResource MutedBrush}"
                                            Text="Show hidden &amp; system files" />
                                    </StackPanel>
                                    <CheckBox
                                        x:Name="ForceCheck"
                                        Grid.Column="1"
                                        VerticalAlignment="Center"
                                        Checked="ForceCheck_Changed"
                                        Style="{StaticResource DarkCheckBox}"
                                        Unchecked="ForceCheck_Changed" />
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!--  Command Info Panel  -->
                        <Border
                            Grid.Row="2"
                            Grid.Column="2"
                            Padding="16"
                            Background="#05FFFFFF"
                            BorderBrush="{StaticResource BorderBrush}"
                            BorderThickness="1"
                            CornerRadius="12">
                            <StackPanel>
                                <TextBlock
                                    Margin="0,0,0,10"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource MutedBrush}"
                                    Text="COMMAND INFO" />
                                <TextBlock
                                    x:Name="CmdInfoText"
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="12"
                                    Foreground="{StaticResource TextBrush}"
                                    Text="Select a suggestion to see command details."
                                    TextWrapping="Wrap" />
                            </StackPanel>
                        </Border>

                        <!--  Risk Warning Banner  -->
                        <Border
                            x:Name="RiskBanner"
                            Grid.Row="4"
                            Grid.Column="0"
                            Grid.ColumnSpan="3"
                            Padding="16,12"
                            CornerRadius="10">
                            <Border.Background>
                                <SolidColorBrush Color="#1AF59E0B" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4DF59E0B" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock
                                    x:Name="RiskIcon"
                                    Margin="0,0,12,0"
                                    VerticalAlignment="Center"
                                    FontSize="18"
                                    Text="⚠" />
                                <StackPanel VerticalAlignment="Center">
                                    <TextBlock
                                        x:Name="RiskTitle"
                                        FontFamily="{StaticResource MonoFont}"
                                        FontSize="12"
                                        FontWeight="Bold"
                                        Foreground="#FCD34D"
                                        Text="Medium Risk" />
                                    <TextBlock
                                        x:Name="RiskDesc"
                                        Margin="0,2,0,0"
                                        FontFamily="{StaticResource MonoFont}"
                                        FontSize="11"
                                        Foreground="#FCD34D"
                                        Opacity="0.8"
                                        Text="Review the command before execution."
                                        TextWrapping="Wrap" />
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>
                </ScrollViewer>

                <!--  Action Row  -->
                <Border
                    Grid.Row="4"
                    Padding="0,16,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,0,10,0"
                            Click="RunBtn_Click"
                            Content="▶  Run Command"
                            Style="{StaticResource PrimaryBtn}" />
                        <Button
                            Margin="0,0,10,0"
                            Click="CopyBtn_Click"
                            Style="{StaticResource GhostBtn}">
                            <TextBlock>
                                <Run Text="⎘ " />
                                <Run Foreground="{StaticResource MutedBrush}" Text="Copy to Clipboard" />
                            </TextBlock>
                        </Button>
                        <Button
                            Click="BackBtn_Click"
                            Content="←  Back to Suggestions"
                            Style="{StaticResource GhostBtn}" />

                    </StackPanel>
                </Border>
            </Grid>

            <!--  Status Bar  -->
            <Border
                Grid.Row="3"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <TextBlock
                        x:Name="StatusBarCmd"
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource MonoFont}"
                        FontSize="11"
                        Foreground="{StaticResource MutedBrush}"
                        Text="No command selected" />
                    <Button
                        Margin="0,0,88,0"
                        Padding="12,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="NewSearchBtn_Click"
                        Content="＋  New Search"
                        FontSize="11"
                        Style="{StaticResource GhostBtn}" />
                    <Button
                        Padding="12,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="HistoryBtn_Click"
                        Content="History  →"
                        FontSize="11"
                        Style="{StaticResource GhostBtn}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>