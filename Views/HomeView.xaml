<!--
    ================================================================
    File: HomeView.xaml
    Project: OpticCli
    Namespace: OpticCli.Views
    Description: The main home/search screen. Shows the search box,
    quick prompt chips, and the Discover Commands button.
    This is the first screen the user sees on launch.
    ================================================================
-->
<Window
    x:Class="OpticCli.Views.HomeView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="clr-namespace:OpticCli.Views"
    Title="OpticCli – AI Terminal"
    Width="1100"
    Height="700"
    MinWidth="900"
    MinHeight="600"
    AllowsTransparency="True"
    Background="{StaticResource SurfaceBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <Window.Resources>
        <!--  Quick-prompt chip style  -->
        <Style x:Key="ChipBtn" TargetType="Button">
            <Setter Property="Background" Value="#08FFFFFF" />
            <Setter Property="Foreground" Value="{StaticResource MutedBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="FontFamily" Value="{StaticResource MonoFont}" />
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border
                            Padding="{TemplateBinding Padding}"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="8">
                            <ContentPresenter />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Background" Value="#0A00E5FF" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="1"
        CornerRadius="0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <!--  Title bar  -->
                <RowDefinition Height="36" />
                <!--  Tab bar  -->
                <RowDefinition Height="*" />
                <!--  Content  -->
                <RowDefinition Height="28" />
                <!--  Status bar  -->
            </Grid.RowDefinitions>

            <!--  ── Title Bar ──  -->
            <local:TitleBarControl Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

            <!--  ── Tab Bar ──  -->
            <Border
                Grid.Row="1"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
                <StackPanel
                    Margin="16,0"
                    VerticalAlignment="Stretch"
                    Orientation="Horizontal">
                    <Border
                        Width="1259"
                        Margin="0,0,0,-1"
                        Padding="16,0"
                        Background="Transparent"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="0,0,0,0.8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12"
                            Foreground="{StaticResource AccentBrush}"
                            Text="⌂  Terminal" />
                    </Border>
                </StackPanel>
            </Border>

            <!--  ── Main Content: Hero ──  -->
            <Grid Grid.Row="2">
                <!--  Radial glow background  -->
                <Border>
                    <Border.Background>
                        <RadialGradientBrush Center="0.5,0.4" RadiusX="0.5" RadiusY="0.45">
                            <GradientStop Offset="0" Color="#0A00E5FF" />
                            <GradientStop Offset="1" Color="Transparent" />
                        </RadialGradientBrush>
                    </Border.Background>
                </Border>

                <StackPanel
                    MaxWidth="700"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">

                    <!--  Logo Area  -->
                    <StackPanel Margin="0,0,0,44" HorizontalAlignment="Center">
                        <!--  Icon box  -->
                        <Border
                            Width="72"
                            Height="72"
                            Margin="0,0,0,12"
                            HorizontalAlignment="Center"
                            CornerRadius="18">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Offset="0" Color="#2600E5FF" />
                                    <GradientStop Offset="1" Color="#267C3AED" />
                                </LinearGradientBrush>
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4D00E5FF" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="32"
                                Text="⚡" />
                        </Border>

                        <!--  OpticCli title  -->
                        <TextBlock Margin="0,0,0,6" HorizontalAlignment="Center">
                            <TextBlock.Text>OpticCli</TextBlock.Text>
                            <TextBlock.Foreground>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                    <GradientStop Offset="0" Color="#00E5FF" />
                                    <GradientStop Offset="1" Color="#A78BFA" />
                                </LinearGradientBrush>
                            </TextBlock.Foreground>
                            <TextBlock.FontFamily>
                                <FontFamily>Segoe UI</FontFamily>
                            </TextBlock.FontFamily>
                            <TextBlock.FontSize>34</TextBlock.FontSize>
                            <TextBlock.FontWeight>Bold</TextBlock.FontWeight>
                        </TextBlock>

                        <TextBlock
                            Margin="0,0,0,10"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Foreground="{StaticResource MutedBrush}"
                            Text="AI-ASSISTED VISUAL COMMAND DISCOVERY" />

                        <!--  AI Online badge  -->
                        <Border
                            Margin="0,0,0,0"
                            Padding="14,5"
                            HorizontalAlignment="Center"
                            CornerRadius="20">
                            <Border.Background>
                                <SolidColorBrush Color="#1400E5FF" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#4000E5FF" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <StackPanel Orientation="Horizontal">
                                <Ellipse
                                    Width="7"
                                    Height="7"
                                    Margin="0,0,7,0"
                                    VerticalAlignment="Center"
                                    Fill="{StaticResource AccentBrush}" />
                                <TextBlock
                                    FontFamily="{StaticResource MonoFont}"
                                    FontSize="11"
                                    Foreground="{StaticResource AccentBrush}"
                                    Text="AI Command Assistant Online" />
                            </StackPanel>
                        </Border>
                    </StackPanel>

                    <!--  ── Search Box ──  -->
                    <Grid Margin="0,0,0,18">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>

                        <Border
                            x:Name="SearchBorder"
                            Grid.Column="0"
                            Grid.ColumnSpan="4"
                            BorderThickness="1.5"
                            CornerRadius="12">
                            <Border.Background>
                                <SolidColorBrush Color="#08FFFFFF" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#2A3040" />
                            </Border.BorderBrush>
                        </Border>

                        <!--  Prompt symbol  -->
                        <TextBlock
                            Grid.Column="0"
                            Margin="18,0,0,0"
                            VerticalAlignment="Center"
                            FontSize="20"
                            FontWeight="Bold"
                            Foreground="{StaticResource AccentBrush}"
                            Text="›" />

                        <!--  Input field  -->
                        <TextBox
                            x:Name="NLInput"
                            Grid.Column="1"
                            Padding="8,16"
                            VerticalAlignment="Center"
                            Background="Transparent"
                            BorderThickness="0"
                            CaretBrush="{StaticResource AccentBrush}"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="15"
                            Foreground="{StaticResource TextBrush}"
                            GotFocus="NLInput_GotFocus"
                            KeyDown="NLInput_KeyDown"
                            Text="Find all large PDF files on this drive..."
                            TextChanged="NLInput_TextChanged" />
                        <!--  Validation Message  -->
                        <TextBlock
                            x:Name="ValidationMsg"
                            Margin="0,8,0,0"
                            HorizontalAlignment="Center"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12"
                            Foreground="#EF4444"
                            Text="⚠  Please enter a command description to search."
                            Visibility="Collapsed" />
                        <!--  Mic button  -->
                        <Button
                            Grid.Column="2"
                            Width="40"
                            Height="40"
                            Margin="0,0,6,0"
                            VerticalAlignment="Center"
                            Background="#08FFFFFF"
                            BorderBrush="{StaticResource Border2Brush}"
                            BorderThickness="1"
                            Click="MicBtn_Click"
                            Content="🎙"
                            Cursor="Hand"
                            FontSize="16"
                            Foreground="{StaticResource MutedBrush}">
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        Width="40"
                                        Height="40"
                                        Background="{TemplateBinding Background}"
                                        BorderBrush="{TemplateBinding BorderBrush}"
                                        BorderThickness="{TemplateBinding BorderThickness}"
                                        CornerRadius="8">
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                        <!--  Run button  -->
                        <Button
                            Grid.Column="3"
                            Width="44"
                            Height="44"
                            Margin="0,0,8,0"
                            VerticalAlignment="Center"
                            Click="DiscoverBtn_Click"
                            Content="▶"
                            Cursor="Hand"
                            FontSize="16"
                            FontWeight="Bold"
                            Foreground="#FF000000">
                            <Button.Background>
                                <SolidColorBrush Color="#00E5FF" />
                            </Button.Background>
                            <Button.Template>
                                <ControlTemplate TargetType="Button">
                                    <Border
                                        Width="44"
                                        Height="44"
                                        Background="{TemplateBinding Background}"
                                        CornerRadius="10">
                                        <Border.Effect>
                                            <DropShadowEffect
                                                BlurRadius="16"
                                                Opacity="0.5"
                                                ShadowDepth="0"
                                                Color="#00E5FF" />
                                        </Border.Effect>
                                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter Property="Background" Value="#33EEFF" />
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </Button.Template>
                        </Button>

                    </Grid>

                    <!--  ── Discover Commands Button ──  -->
                    <Button
                        Margin="0,0,0,30"
                        HorizontalAlignment="Center"
                        Click="DiscoverBtn_Click"
                        Cursor="Hand">
                        <Button.Template>
                            <ControlTemplate TargetType="Button">
                                <Border Padding="36,13" CornerRadius="50">
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                            <GradientStop Offset="0" Color="#2000E5FF" />
                                            <GradientStop Offset="1" Color="#207C3AED" />
                                        </LinearGradientBrush>
                                    </Border.Background>
                                    <Border.BorderBrush>
                                        <SolidColorBrush Color="#5900E5FF" />
                                    </Border.BorderBrush>
                                    <Border.BorderThickness>1</Border.BorderThickness>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock
                                            VerticalAlignment="Center"
                                            FontFamily="{StaticResource UIFont}"
                                            FontSize="13"
                                            FontWeight="Bold"
                                            Foreground="{StaticResource AccentBrush}"
                                            Text="DISCOVER COMMANDS" />
                                        <Border
                                            Margin="14,0,0,0"
                                            Padding="8,2"
                                            VerticalAlignment="Center"
                                            Background="#2600E5FF"
                                            BorderBrush="{StaticResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6">
                                            <TextBlock
                                                FontFamily="{StaticResource MonoFont}"
                                                FontSize="11"
                                                Foreground="{StaticResource AccentBrush}"
                                                Text="⏎ Enter" />
                                        </Border>
                                    </StackPanel>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Cursor" Value="Hand" />
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Button.Template>
                    </Button>

                    <!--  ── Quick Prompt Chips ──  -->
                    <WrapPanel HorizontalAlignment="Center">
                        <Button
                            Margin="4"
                            Click="Chip_Click"
                            Content="⟩ Find all PDF files"
                            Style="{StaticResource ChipBtn}" />
                        <Button
                            Margin="4"
                            Click="Chip_Click"
                            Content="⟩ Kill all python processes"
                            Style="{StaticResource ChipBtn}" />
                        <Button
                            Margin="4"
                            Click="Chip_Click"
                            Content="⟩ Show network connections"
                            Style="{StaticResource ChipBtn}" />
                        <Button
                            Margin="4"
                            Click="Chip_Click"
                            Content="⟩ List running services"
                            Style="{StaticResource ChipBtn}" />
                        <Button
                            Margin="4"
                            Click="Chip_Click"
                            Content="⟩ Delete temp files"
                            Style="{StaticResource ChipBtn}" />
                        <Button
                            Margin="4"
                            Click="Chip_Click"
                            Content="⟩ Check disk usage"
                            Style="{StaticResource ChipBtn}" />
                    </WrapPanel>

                </StackPanel>
            </Grid>

            <!--  ── Status Bar ──  -->
            <Border
                Grid.Row="3"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                        <Ellipse
                            Width="6"
                            Height="6"
                            Margin="0,0,6,0"
                            Fill="{StaticResource GreenBrush}" />
                        <TextBlock
                            Margin="0,0,24,0"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Foreground="{StaticResource MutedBrush}"
                            Text="PowerShell 7.4.0" />
                        <Ellipse
                            Width="6"
                            Height="6"
                            Margin="0,0,6,0"
                            Fill="{StaticResource GreenBrush}" />
                        <TextBlock
                            Margin="0,0,24,0"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="11"
                            Foreground="{StaticResource MutedBrush}"
                            Text="AI Model: llama-3.3-70b-versatile" />

                    </StackPanel>
                    <Button
                        Padding="12,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="HistoryBtn_Click"
                        Content="History  →"
                        FontSize="11"
                        Style="{StaticResource GhostBtn}" />
                </Grid>
            </Border>

        </Grid>
    </Border>
</Window>
