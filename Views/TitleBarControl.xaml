<!--
    ================================================================
    File: TitleBarControl.xaml
    Project: OpticCli
    Namespace: OpticCli.Views
    Description: Reusable custom title bar used across all screens.
    Contains the traffic light buttons and app status text.
    ================================================================
-->
<UserControl
    x:Class="OpticCli.Views.TitleBarControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Height="42">
    <Border
        Background="{StaticResource Surface2Brush}"
        BorderBrush="{StaticResource BorderBrush}"
        BorderThickness="0,0,0,1">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!--  Traffic Lights  -->
            <StackPanel
                Grid.Column="0"
                Margin="16,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Ellipse
                    Width="13"
                    Height="13"
                    Margin="0,0,8,0"
                    Cursor="Hand"
                    Fill="#FF5F57"
                    MouseLeftButtonDown="CloseBtn_Click" />
                <Ellipse
                    Width="13"
                    Height="13"
                    Margin="0,0,8,0"
                    Cursor="Hand"
                    Fill="#FFBD2E"
                    MouseLeftButtonDown="MinimizeBtn_Click" />
                <Ellipse
                    Width="13"
                    Height="13"
                    Cursor="Hand"
                    Fill="#28C840"
                    MouseLeftButtonDown="MaximizeBtn_Click" />
            </StackPanel>

            <!--  App Name  -->
            <TextBlock
                x:Name="TitleText"
                Grid.Column="1"
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontFamily="{StaticResource UIFont}"
                FontSize="13"
                FontWeight="Bold"
                Foreground="{StaticResource MutedBrush}"
                Text="OpticCli · AI Terminal" />

            <!--  Status  -->
            <StackPanel
                Grid.Column="2"
                Margin="16,0"
                VerticalAlignment="Center"
                Orientation="Horizontal">
                <Ellipse
                    Width="7"
                    Height="7"
                    Margin="0,0,6,0"
                    Fill="{StaticResource GreenBrush}" />
                <TextBlock
                    x:Name="StatusText"
                    FontFamily="{StaticResource MonoFont}"
                    FontSize="11"
                    Foreground="{StaticResource GreenBrush}"
                    Text="Connected · PowerShell 7.4" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
