<!--
    ================================================================
    File: SuggestionsView.xaml
    Project: OpticCli
    Namespace: OpticCli.Views
    Description: The suggestions screen. Shows 3 AI-generated command
    cards after the user submits a query. The user can
    select one to customize or run it directly.
    ================================================================
-->
<Window
    x:Class="OpticCli.Views.SuggestionsView"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:conv="clr-namespace:OpticCli.Converters"
    xmlns:local="clr-namespace:OpticCli.Views"
    xmlns:models="clr-namespace:OpticCli.Models"
    Title="OpticCli – AI Suggestions"
    Width="1100"
    Height="700"
    AllowsTransparency="True"
    Background="{StaticResource SurfaceBrush}"
    ResizeMode="CanResize"
    WindowStartupLocation="CenterScreen"
    WindowState="Maximized"
    WindowStyle="None">

    <Window.Resources>
        <conv:RiskToForegroundConverter x:Key="RiskFg" />
        <conv:RiskToBackgroundConverter x:Key="RiskBg" />
        <conv:RiskToBorderConverter x:Key="RiskBd" />
        <conv:RiskToAccentConverter x:Key="RiskAccent" />
        <conv:BoolToVisibilityConverter x:Key="BoolVis" />

        <!--  Command card style  -->
        <Style x:Key="CmdCard" TargetType="Border">
            <Setter Property="Background" Value="#05FFFFFF" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="0,0,0,10" />
            <Setter Property="Cursor" Value="Hand" />
        </Style>
    </Window.Resources>

    <Border BorderBrush="{StaticResource BorderBrush}" BorderThickness="1">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42" />
                <RowDefinition Height="36" />
                <RowDefinition Height="*" />
                <RowDefinition Height="28" />
            </Grid.RowDefinitions>

            <!--  Title Bar  -->
            <local:TitleBarControl Grid.Row="0" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown" />

            <!--  Tab Bar  -->
            <Border
                Grid.Row="1"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,0,0,1">
                <StackPanel
                    Margin="16,0"
                    VerticalAlignment="Stretch"
                    Orientation="Horizontal">
                    <Border
                        Width="1259"
                        Margin="0,0,0,-1"
                        Padding="16,0"
                        BorderBrush="{StaticResource AccentBrush}"
                        BorderThickness="0,0,0,0.8">
                        <TextBlock
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12"
                            Foreground="{StaticResource AccentBrush}"
                            Text="⌂  Terminal" />
                    </Border>
                </StackPanel>
            </Border>

            <!--  ── Body ──  -->
            <Grid Grid.Row="2" Margin="28,20,28,16">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <!--  Query echo  -->
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <!--  Section label  -->
                    <RowDefinition Height="10" />
                    <RowDefinition Height="*" />
                    <!--  Cards list  -->
                    <RowDefinition Height="16" />
                    <RowDefinition Height="Auto" />
                    <!--  Action row  -->
                </Grid.RowDefinitions>

                <!--  Query Echo Banner  -->
                <Border
                    Grid.Row="0"
                    Padding="18,12"
                    CornerRadius="10">
                    <Border.Background>
                        <SolidColorBrush Color="#0A00E5FF" />
                    </Border.Background>
                    <Border.BorderBrush>
                        <SolidColorBrush Color="#3300E5FF" />
                    </Border.BorderBrush>
                    <Border.BorderThickness>1</Border.BorderThickness>
                    <Grid>
                        <StackPanel VerticalAlignment="Center" Orientation="Horizontal">
                            <TextBlock
                                Margin="0,0,6,0"
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="13"
                                FontWeight="Bold"
                                Foreground="{StaticResource AccentBrush}"
                                Text="You asked: " />
                            <TextBlock
                                x:Name="QueryEchoText"
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="13"
                                Foreground="{StaticResource TextBrush}"
                                Text="&quot;Delete all temp files&quot;" />
                        </StackPanel>
                        <Border
                            Padding="12,4"
                            HorizontalAlignment="Right"
                            CornerRadius="20">
                            <Border.Background>
                                <SolidColorBrush Color="#1A7C3AED" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#667C3AED" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <TextBlock
                                FontFamily="{StaticResource MonoFont}"
                                FontSize="11"
                                Foreground="#A78BFA"
                                Text="⚡  3 commands found" />
                        </Border>
                    </Grid>
                </Border>

                <!--  Section Label  -->
                <StackPanel
                    Grid.Row="2"
                    VerticalAlignment="Center"
                    Orientation="Horizontal">
                    <TextBlock
                        FontFamily="{StaticResource MonoFont}"
                        FontSize="11"
                        Foreground="{StaticResource MutedBrush}"
                        Text="SUGGESTED COMMANDS · Select one to continue" />
                    <Rectangle
                        Width="400"
                        Height="1"
                        Margin="12,0,0,0"
                        HorizontalAlignment="Stretch"
                        VerticalAlignment="Center"
                        Fill="{StaticResource BorderBrush}" />
                </StackPanel>

                <!--  ── Command Cards List ──  -->
                <ScrollViewer Grid.Row="4" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="CommandsPanel" />
                </ScrollViewer>

                <!--  ── Action Row ──  -->
                <Border
                    Grid.Row="6"
                    Padding="0,16,0,0"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                    <StackPanel Orientation="Horizontal">
                        <Button
                            Margin="0,0,10,0"
                            Click="CustomizeBtn_Click"
                            Content="⚙  Customize Selected"
                            Style="{StaticResource PrimaryBtn}" />
                        <Button
                            Margin="0,0,10,0"
                            Click="RunDirectBtn_Click"
                            Content="▶  Run As-Is"
                            Style="{StaticResource GhostBtn}" />

                        <TextBlock
                            x:Name="SelInfo"
                            Margin="16,0,0,0"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            FontFamily="{StaticResource MonoFont}"
                            FontSize="12"
                            Foreground="{StaticResource MutedBrush}"
                            Text="1 command selected" />
                    </StackPanel>
                </Border>
            </Grid>

            <!--  Status Bar  -->
            <Border
                Grid.Row="3"
                Background="{StaticResource Surface2Brush}"
                BorderBrush="{StaticResource BorderBrush}"
                BorderThickness="0,1,0,0">
                <Grid Margin="20,0">
                    <TextBlock
                        VerticalAlignment="Center"
                        FontFamily="{StaticResource MonoFont}"
                        FontSize="11"
                        Foreground="{StaticResource MutedBrush}"
                        Text="AI Model: Code Llama 34B · Response: 0.4s" />
                    <Button
                        Margin="0,0,88,0"
                        Padding="12,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="NewSearchBtn_Click"
                        Content="＋  New Search"
                        FontSize="11"
                        Style="{StaticResource GhostBtn}" />
                    <Button
                        Margin="0,0,0,0"
                        Padding="12,4"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Click="HistoryBtn_Click"
                        Content="History  →"
                        FontSize="11"
                        Style="{StaticResource GhostBtn}" />
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
